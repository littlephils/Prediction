# --- Admin access -----------------------------------------------------------
# Secret key for the admin panel. Visit /admin?key=THIS_VALUE
ADMIN_KEY=partytime

# --- Odds tuning ------------------------------------------------------------
# Compression constant: higher = odds fall faster as the pool grows.
ODDS_K=0.005

# --- Storage (Vercel KV / Upstash Redis) ------------------------------------
# Leave these UNSET for local development — the app falls back to an in-memory
# store automatically (data lives only as long as `next dev` is running).
#
# For production, add the "Upstash for Redis" integration in the Vercel
# Marketplace (this is what Vercel KV is now provisioned through). Vercel will
# inject these automatically; locally you can paste them in from the dashboard.
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
